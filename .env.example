# HELIX Growth Doctor — copy to .env.local
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Narrative engine — Ollama first (local/private), Claude fallback
OLLAMA_BASE_URL=            # e.g. http://localhost:11434
OLLAMA_MODEL=llama3.1
ANTHROPIC_API_KEY=
CONTENT_MODEL=claude-sonnet-5

# Bot delivery
TELEGRAM_BOT_TOKEN=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_WABA_ID=          # WhatsApp Business Account id — needed to register templates (/api/templates/sync)
RESEND_API_KEY=
EMAIL_FROM=HELIX <hello@example.com>

# Cross-product: HELIX DASHBOARDS pulls /api/export/growth-metrics
EXPORT_SECRET=
CRON_SECRET=
